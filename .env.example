# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Railway provee DATABASE_URL automáticamente al agregar el plugin de Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/precioalerta

# ─── Redis ────────────────────────────────────────────────────────────────────
# Railway provee REDIS_URL automáticamente al agregar el plugin de Redis
REDIS_URL=redis://localhost:6379

# ─── Scraping ─────────────────────────────────────────────────────────────────
# Delay entre requests (ms) — respetuoso con los servidores
SCRAPE_DELAY_MS=1500
# Máximo de páginas por categoría
SCRAPE_MAX_PAGES=5
# Timeout de cada request (ms)
SCRAPE_TIMEOUT_MS=10000

# ─── Cron schedules ───────────────────────────────────────────────────────────
# Precios generales: cada 6 horas
CRON_PRECIOS=0 */6 * * *
# Productos en oferta: cada 2 horas
CRON_OFERTAS=0 */2 * * *
# Verificación de alertas: cada 30 minutos
CRON_ALERTAS=*/30 * * * *
# Resumen semanal: lunes 8am
CRON_RESUMEN=0 8 * * 1

# ─── Firebase Cloud Messaging (push notifications) ────────────────────────────
# Obtener en: console.firebase.google.com → Project Settings → Service Accounts
FCM_SERVER_KEY=tu_server_key_aqui

# ─── Seguridad ────────────────────────────────────────────────────────────────
API_KEY=precioalerta_dev_key_cambiar_en_produccion
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
